@rendermode InteractiveServer

<header class="navbar">
    <div class="navbar-inner">
        <NavLink class="brand" href="/blog" Match="NavLinkMatch.Prefix" @onclick="CloseMenu">
            <span class="brand-mark">72</span>
            <span class="brand-copy">
                <strong>Zero72</strong>
                <small>技术与思考</small>
            </span>
        </NavLink>

        <nav class="nav-links @NavMenuCssClass" aria-label="主导航">
            <NavLink href="/blog" Match="NavLinkMatch.Prefix" @onclick="CloseMenu">文章</NavLink>
            <NavLink href="/projects" @onclick="CloseMenu">项目</NavLink>
            <NavLink href="/notes" @onclick="CloseMenu">思考</NavLink>
            <NavLink href="/reading" @onclick="CloseMenu">阅读记录</NavLink>
            <NavLink href="/books" @onclick="CloseMenu">书架</NavLink>
            <a href="https://github.com/mmgdh" target="_blank" rel="noreferrer" @onclick="CloseMenu">关于</a>
        </nav>

        <div class="nav-actions">
            <button class="theme-button" type="button" aria-label="切换明暗主题"
                    title="切换明暗主题" onclick="window.zero72Theme?.toggle()">
                <span class="theme-glyph" aria-hidden="true"></span>
            </button>
            <button class="menu-button" type="button" aria-label="打开或关闭导航"
                    aria-expanded="@_menuOpen" @onclick="ToggleMenu">
                <span></span>
                <span></span>
            </button>
        </div>
    </div>
</header>

@code {
    private bool _menuOpen;

    private string NavMenuCssClass => _menuOpen ? "is-open" : string.Empty;

    /// <summary>切换移动端导航菜单的显示状态。</summary>
    private void ToggleMenu()
    {
        _menuOpen = !_menuOpen;
    }

    /// <summary>用户完成导航后关闭移动端菜单。</summary>
    private void CloseMenu()
    {
        _menuOpen = false;
    }
}
