@page "/notes"
@inject HttpClient Http

<PageTitle>思考记录 - Zero72 博客</PageTitle>

<main class="main-content page">
    <section class="section-index">
        <header class="heading">
            <h2>
                <span class="heading-icon">N</span>
                <span>思考记录</span>
            </h2>
            <div class="description">生活、项目、学习，以及那些暂时不需要展开成长文的想法。</div>
        </header>

        @if (thoughts is null)
        {
            <section class="status-panel">正在加载思考记录...</section>
        }
        else if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <section class="status-panel status-error">@errorMessage</section>
        }
        else if (thoughts.Count == 0)
        {
            <div class="empty-note">更多想法会随着这个数字花园一起生长。</div>
        }
        else
        {
            <div class="thought-timeline">
                @foreach (var thought in thoughts)
                {
                    <article class="thought-card">
                        <time datetime="@FormatMachineDate(thought.OccurredAt)">@FormatDisplayDate(thought.OccurredAt)</time>
                        <p>@thought.Content</p>
                        @if (!string.IsNullOrWhiteSpace(thought.ImageUrl))
                        {
                            <img src="@thought.ImageUrl" alt="思考记录配图" loading="lazy" />
                        }
                    </article>
                }
            </div>
        }
    </section>
</main>

@code {
    private List<ThoughtItem>? thoughts;
    private string? errorMessage;

    // 从公开接口加载已经发布的思考记录。
    protected override async Task OnInitializedAsync()
    {
        try
        {
            thoughts = await Http.GetFromJsonAsync<List<ThoughtItem>>("api/thoughts") ?? [];
        }
        catch (Exception)
        {
            thoughts = [];
            errorMessage = "无法从后端接口读取思考记录。";
        }
    }

    // 将发生时间格式化为适合时间线阅读的本地日期。
    private static string FormatDisplayDate(DateTimeOffset occurredAt)
    {
        return occurredAt.ToLocalTime().ToString("yyyy年MM月dd日 HH:mm");
    }

    // 输出供 time 元素使用的机器可读时间。
    private static string FormatMachineDate(DateTimeOffset occurredAt)
    {
        return occurredAt.ToString("O");
    }
}
