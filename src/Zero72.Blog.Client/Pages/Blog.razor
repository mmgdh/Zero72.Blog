@page "/blog"
@inject HttpClient Http

<PageTitle>Zero72 博客</PageTitle>

<main class="main-content page">
    <header class="hero hero-index">
        <div class="hero-wrapper">
            <span class="eyebrow">Zero72 · Digital Garden</span>
            <h1>把复杂技术，<br />写成清晰答案。</h1>
            <p class="hero-description">
                我是林庆汉，一名专注 .NET 与现代 Web 的开发者。这里沉淀真实项目中的工程实践、排错过程和长期思考。
            </p>
            <p class="large-links">
                <a class="large-link" href="#posts">阅读最新文章</a>
                <a class="large-link" href="https://github.com/mmgdh" target="_blank" rel="noopener noreferrer">在 GitHub 找到我</a>
            </p>
            <div class="hero-tags" aria-label="关注领域">
                <span>.NET</span><span>Blazor</span><span>PostgreSQL</span><span>Docker</span>
            </div>
        </div>
        <div class="hero-image-container">
            <img src="img/author-cover.jpg"
                 class="hero-image"
                 alt="Zero72 的个人照片"
                 width="1280"
                 height="720"
                 decoding="async"
                 fetchpriority="high" />
        </div>
    </header>

    @if (posts is null)
    {
        <section class="status-panel">正在加载文章...</section>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <section class="status-panel status-error">@errorMessage</section>
    }
    else if (posts.Count == 0)
    {
        <section class="status-panel">还没有已发布的文章。</section>
    }
    else
    {
        var latestArticles = posts.Take(5).ToList();
        var highlightPosts = posts.Take(9).ToList();

        <section class="section-index" id="posts">
            <header class="heading">
                <div>
                    <span class="section-kicker">Latest writing</span>
                    <h2>最新文章</h2>
                </div>
                <div class="description">工程实践、问题拆解与技术笔记</div>
            </header>
            <div class="posts">
                @foreach (var post in latestArticles)
                {
                    <NavLink class="post" href="@GetPostUrl(post)">
                        <div>
                            <h3>@post.Title</h3>
                            <p>阅读这篇文章</p>
                        </div>
                        <time datetime="@FormatMachineDate(post.PublishedAt)">@FormatDisplayDate(post.PublishedAt)</time>
                    </NavLink>
                }
            </div>
        </section>

        <section class="section-index">
            <header class="heading">
                <div>
                    <span class="section-kicker">Explore more</span>
                    <h2>继续探索</h2>
                </div>
                <div class="description">更多值得慢慢阅读的内容</div>
            </header>
            <div class="cards">
                @foreach (var post in highlightPosts)
                {
                    <NavLink class="card article-card" href="@GetPostUrl(post)">
                        <span class="article-initial">@GetInitial(post.Title)</span>
                        <h3>@post.Title</h3>
                        <span class="article-meta">@FormatDisplayDate(post.PublishedAt) · 查看文章 →</span>
                    </NavLink>
                }
            </div>
        </section>
    }
</main>

@code {
    private List<BlogPostSummary>? posts;
    private string? errorMessage;

    /// <summary>加载公开发布的博客文章列表。</summary>
    protected override async Task OnInitializedAsync()
    {
        try
        {
            posts = await Http.GetFromJsonAsync<List<BlogPostSummary>>("api/posts") ?? [];
        }
        catch (Exception)
        {
            posts = [];
            errorMessage = "无法从后端接口读取文章。";
        }
    }

    /// <summary>生成文章详情页地址。</summary>
    private static string GetPostUrl(BlogPostSummary post)
    {
        return $"/posts/{post.Slug}";
    }

    /// <summary>将发布时间转换为界面使用的日期。</summary>
    private static string FormatDisplayDate(DateTimeOffset? publishedAt)
    {
        return publishedAt?.ToLocalTime().ToString("MM月dd日") ?? "草稿";
    }

    /// <summary>将发布时间转换为机器可读日期。</summary>
    private static string FormatMachineDate(DateTimeOffset? publishedAt)
    {
        return publishedAt?.ToString("yyyy-MM-dd") ?? string.Empty;
    }

    /// <summary>提取文章标题首字符作为视觉标识。</summary>
    private static string GetInitial(string value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Z" : value.Trim()[0].ToString().ToUpperInvariant();
    }
}
