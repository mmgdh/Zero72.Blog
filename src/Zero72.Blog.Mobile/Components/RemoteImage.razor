@inject BlogApiClient Api
@inject AppLogService Logs

@if (!hasError && !string.IsNullOrWhiteSpace(resolvedSource))
{
    <img @key="resolvedSource" class="@Class" src="@resolvedSource" alt="@Alt" loading="@(Lazy ? "lazy" : "eager")" @onload="HandleLoadedAsync" @onerror="HandleErrorAsync" />
}
else if (Fallback is not null)
{
    @Fallback
}
else if (hasError)
{
    <span class="remote-image-error" role="status">图片加载失败</span>
}

@code {
    private string? loadedPath;
    private string? publicUrl;
    private string? resolvedSource;
    private bool hasError;
    private int loadVersion;

    /// <summary>
    /// 服务器返回的相对或同源绝对图片地址。
    /// </summary>
    [Parameter]
    public string? ImagePath { get; set; }

    /// <summary>
    /// 图片替代文本。
    /// </summary>
    [Parameter]
    public string Alt { get; set; } = string.Empty;

    /// <summary>
    /// 应用于 img 元素的样式类。
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    /// 是否允许 WebView 延迟解码图片。
    /// </summary>
    [Parameter]
    public bool Lazy { get; set; } = true;

    /// <summary>
    /// 图片读取失败时显示的替代内容。
    /// </summary>
    [Parameter]
    public RenderFragment? Fallback { get; set; }

    /// <summary>
    /// 将网页使用的上传路径直接转换为当前博客服务器上的完整图片地址。
    /// </summary>
    protected override async Task OnParametersSetAsync()
    {
        if (string.Equals(loadedPath, ImagePath, StringComparison.Ordinal))
        {
            return;
        }

        loadedPath = ImagePath;
        publicUrl = Api.ToPublicUrl(ImagePath);
        resolvedSource = null;
        hasError = false;
        var requestedVersion = ++loadVersion;
        if (publicUrl is null)
        {
            await Logs.WarningAsync("图片", $"无法生成公开图片地址，原始值：{ImagePath ?? "（空）"}");
            return;
        }

        await Logs.InfoAsync("图片", $"原生客户端准备读取：{publicUrl}");
        try
        {
            var dataUrl = await Api.GetImageDataUrlAsync(publicUrl);
            if (requestedVersion != loadVersion)
            {
                return;
            }

            resolvedSource = dataUrl;
        }
        catch (Exception exception)
        {
            if (requestedVersion != loadVersion)
            {
                return;
            }

            hasError = true;
            await Logs.ErrorAsync("图片", $"原生读取失败：{publicUrl}；{exception.GetType().Name}：{exception.Message}");
        }
    }

    /// <summary>
    /// 记录 WebView 已成功解码并显示远程图片。
    /// </summary>
    private Task HandleLoadedAsync()
    {
        return Logs.InfoAsync("图片", $"WebView 已显示内嵌图片：{publicUrl}");
    }

    /// <summary>
    /// WebView 无法解码已经由原生客户端读取的内嵌图片时显示占位内容。
    /// </summary>
    private async Task HandleErrorAsync()
    {
        resolvedSource = null;
        hasError = true;
        await Logs.ErrorAsync("图片", $"WebView 无法解码内嵌图片：{publicUrl ?? ImagePath ?? "（空）"}");
    }
}
