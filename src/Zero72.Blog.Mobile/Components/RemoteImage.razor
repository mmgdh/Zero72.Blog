@inject BlogApiClient Api

@if (!hasError && !string.IsNullOrWhiteSpace(resolvedSource))
{
    <img class="@Class" src="@resolvedSource" alt="@Alt" loading="@(Lazy ? "lazy" : "eager")" @onerror="HandleError" />
}
else if (Fallback is not null)
{
    @Fallback
}
else if (hasError)
{
    <span class="remote-image-error" role="status">图片加载失败</span>
}

@code {
    private string? loadedPath;
    private string? resolvedSource;
    private bool hasError;

    /// <summary>
    /// 服务器返回的相对或同源绝对图片地址。
    /// </summary>
    [Parameter]
    public string? ImagePath { get; set; }

    /// <summary>
    /// 图片替代文本。
    /// </summary>
    [Parameter]
    public string Alt { get; set; } = string.Empty;

    /// <summary>
    /// 应用于 img 元素的样式类。
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    /// 是否允许 WebView 延迟解码图片。
    /// </summary>
    [Parameter]
    public bool Lazy { get; set; } = true;

    /// <summary>
    /// 图片读取失败时显示的替代内容。
    /// </summary>
    [Parameter]
    public RenderFragment? Fallback { get; set; }

    /// <summary>
    /// 地址变化时同步生成公开资源地址，由已配置网络策略的 Android WebView 直接加载图片。
    /// </summary>
    protected override void OnParametersSet()
    {
        if (string.Equals(loadedPath, ImagePath, StringComparison.Ordinal))
        {
            return;
        }

        loadedPath = ImagePath;
        resolvedSource = Api.ToPublicUrl(ImagePath);
        hasError = false;
    }

    /// <summary>
    /// 浏览器解码或网络请求失败时移除损坏图片并显示调用方提供的占位内容。
    /// </summary>
    private void HandleError() => hasError = true;
}
