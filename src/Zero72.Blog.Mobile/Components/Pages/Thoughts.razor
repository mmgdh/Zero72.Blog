@page "/thoughts"
@inherits AuthenticatedPageBase
@inject IJSRuntime JavaScript

<PageTitle>临时感悟 · Zero72 博客助手</PageTitle>

<section class="page">
    <header class="page-heading heading-row">
        <div><p class="eyebrow">Quick Thoughts</p><h1>临时感悟</h1><p>捕捉此刻的想法，可立即公开或暂存草稿。</p></div>
        <button class="primary compact" @onclick="StartCreate">＋ 写一条</button>
    </header>

    @if (!string.IsNullOrWhiteSpace(errorMessage)) { <div class="alert error">@errorMessage</div> }
    @if (!string.IsNullOrWhiteSpace(successMessage)) { <div class="alert success">@successMessage</div> }

    @if (showEditor)
    {
        <section class="panel editor-panel">
            <div class="section-title"><h2>@(editingId is null ? "写下此刻" : "编辑感悟")</h2></div>
            <div class="form-stack">
                <label class="field"><span>内容</span><textarea rows="8" maxlength="2000" @bind="content" placeholder="此刻在想什么？"></textarea><small>@content.Length / 2000</small></label>
                <label class="field"><span>发生时间</span><input type="datetime-local" @bind="occurredAt" /></label>
                <label class="field">
                    <span>分类标签</span>
                    <input maxlength="200" @bind="tagsText" placeholder="财经、美食、日常" />
                    <small>使用逗号或顿号分隔，最多 @ThoughtTagRules.MaxTagCount 个标签，每个不超过 @ThoughtTagRules.MaxTagLength 个字。</small>
                </label>
                @if (KnownTags.Count > 0)
                {
                    <div class="tag-suggestions" aria-label="常用标签">
                        <span>常用</span>
                        @foreach (var tag in KnownTags)
                        {
                            <button type="button" class="@(IsEditorTagSelected(tag) ? "selected" : null)"
                                    @onclick="() => ToggleEditorTag(tag)">#@tag</button>
                        }
                    </div>
                }
                <label class="toggle-row"><input type="checkbox" @bind="isPublished" /><span><strong>公开显示</strong><small>关闭时仅保存在后台草稿中</small></span></label>
                <label class="field">
                    <span>配图（可选）</span>
                    <InputFile OnChange="UploadImageAsync" accept="image/jpeg,image/png,image/webp,image/gif" />
                    <small>可以直接调用手机拍照或从相册选择，最大 5 MB。</small>
                </label>
                @if (!string.IsNullOrWhiteSpace(imageUrl))
                {
                    <div class="thought-image-preview"><RemoteImage ImagePath="@imageUrl" Alt="感悟配图预览" Lazy="false" /><button class="text-button danger-text" @onclick="RemoveImage">移除图片</button></div>
                }
                <div class="button-row">
                    <button class="primary" disabled="@isSaving" @onclick="SaveAsync">@(isSaving ? "正在同步…" : "保存感悟")</button>
                    <button class="secondary" @onclick="CancelEdit">取消</button>
                </div>
            </div>
        </section>
    }

    @if (isLoading)
    {
        <div class="loading-card">正在读取感悟…</div>
    }
    else if (thoughts.Count == 0)
    {
        <div class="empty-state"><strong>还没有临时感悟</strong><p>想到什么，就从一句话开始。</p></div>
    }
    else
    {
        @if (KnownTags.Count > 0)
        {
            <nav class="mobile-tag-filter" aria-label="按标签筛选感悟">
                <button type="button" class="@(selectedTag is null ? "active" : null)" @onclick="() => SelectTag(null)">全部</button>
                @foreach (var tag in KnownTags)
                {
                    <button type="button" class="@(IsFilterTagSelected(tag) ? "active" : null)" @onclick="() => SelectTag(tag)">#@tag</button>
                }
            </nav>
        }
        <div class="item-list">
            @foreach (var thought in FilteredThoughts.OrderByDescending(item => item.OccurredAt))
            {
                <article class="item-card thought-card">
                    <div class="item-topline">
                        <time>@thought.OccurredAt.ToLocalTime().ToString("yyyy.MM.dd HH:mm")</time>
                        <span class="chip @(thought.IsPublished ? "published" : "draft")">@(thought.IsPublished ? "已公开" : "草稿")</span>
                    </div>
                    @if (GetTags(thought).Length > 0)
                    {
                        <div class="thought-tag-row">
                            @foreach (var tag in GetTags(thought))
                            {
                                <button type="button" @onclick="() => SelectTag(tag)">#@tag</button>
                            }
                        </div>
                    }
                    <p class="thought-content">@thought.Content</p>
                    @if (!string.IsNullOrWhiteSpace(thought.ImageUrl))
                    {
                        <RemoteImage Class="thought-image" ImagePath="@thought.ImageUrl" Alt="感悟配图" />
                    }
                    <div class="card-actions">
                        <button class="text-button" @onclick="() => Edit(thought)">编辑</button>
                        <button class="text-button danger-text" @onclick="() => DeleteAsync(thought)">删除</button>
                    </div>
                </article>
            }
        </div>
    }
</section>

@code {
    private const long MaxUploadBytes = 5 * 1024 * 1024;
    private readonly List<ThoughtItem> thoughts = [];
    private Guid? editingId;
    private string content = string.Empty;
    private DateTime occurredAt = DateTime.Now;
    private string? imageUrl;
    private string tagsText = string.Empty;
    private string? selectedTag;
    private bool isPublished = true;
    private bool isLoading = true;
    private bool isSaving;
    private bool showEditor;
    private string? errorMessage;
    private string? successMessage;

    private IReadOnlyList<string> KnownTags => thoughts
        .SelectMany(GetTags)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(tag => tag, StringComparer.OrdinalIgnoreCase)
        .ToArray();

    private IEnumerable<ThoughtItem> FilteredThoughts => selectedTag is null
        ? thoughts
        : thoughts.Where(thought => GetTags(thought).Contains(selectedTag, StringComparer.OrdinalIgnoreCase));

    /// <summary>
    /// 验证身份并载入全部公开及草稿感悟。
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        if (!await EnsureAuthenticatedAsync()) return;
        await ReloadAsync();
        if (Navigation.Uri.Contains("new=1", StringComparison.OrdinalIgnoreCase)) StartCreate();
    }

    /// <summary>
    /// 从服务器刷新感悟列表。
    /// </summary>
    private async Task ReloadAsync()
    {
        isLoading = true;
        try
        {
            thoughts.Clear();
            thoughts.AddRange(await Api.GetThoughtsAsync());
            if (selectedTag is not null && !KnownTags.Contains(selectedTag, StringComparer.OrdinalIgnoreCase))
            {
                selectedTag = null;
            }
        }
        catch (Exception exception) { errorMessage = exception.Message; }
        finally { isLoading = false; }
    }

    /// <summary>
    /// 重置表单并进入新增模式。
    /// </summary>
    private void StartCreate()
    {
        editingId = null;
        content = string.Empty;
        occurredAt = DateTime.Now;
        imageUrl = null;
        tagsText = string.Empty;
        isPublished = true;
        showEditor = true;
        successMessage = null;
    }

    /// <summary>
    /// 将已有感悟填入编辑器。
    /// </summary>
    private void Edit(ThoughtItem thought)
    {
        editingId = thought.Id;
        content = thought.Content;
        occurredAt = thought.OccurredAt.ToLocalTime().DateTime;
        imageUrl = thought.ImageUrl;
        tagsText = string.Join("、", GetTags(thought));
        isPublished = thought.IsPublished;
        showEditor = true;
    }

    /// <summary>
    /// 上传配图并保存服务器返回的相对地址。
    /// </summary>
    private async Task UploadImageAsync(InputFileChangeEventArgs eventArgs)
    {
        errorMessage = null;
        try
        {
            var file = eventArgs.File;
            await using var stream = file.OpenReadStream(MaxUploadBytes);
            imageUrl = (await Api.UploadImageAsync(stream, file.Name, file.ContentType)).Url;
        }
        catch (Exception exception) { errorMessage = $"图片上传失败：{exception.Message}"; }
    }

    /// <summary>
    /// 校验时间与内容并把感悟同步到博客。
    /// </summary>
    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(content))
        {
            errorMessage = "请填写感悟内容和有效时间。";
            return;
        }

        var tags = ParseTags();
        if (tags.Length > ThoughtTagRules.MaxTagCount)
        {
            errorMessage = $"每条感悟最多添加 {ThoughtTagRules.MaxTagCount} 个标签。";
            return;
        }

        if (tags.Any(tag => tag.Length > ThoughtTagRules.MaxTagLength))
        {
            errorMessage = $"每个标签不能超过 {ThoughtTagRules.MaxTagLength} 个字。";
            return;
        }

        isSaving = true;
        errorMessage = null;
        try
        {
            var occurredAtOffset = new DateTimeOffset(
                occurredAt,
                TimeZoneInfo.Local.GetUtcOffset(occurredAt)).ToUniversalTime();
            await Api.SaveThoughtAsync(editingId, new SaveThoughtRequest(content.Trim(), occurredAtOffset, imageUrl, isPublished, tags));
            showEditor = false;
            successMessage = isPublished ? "感悟已公开同步到博客。" : "感悟已保存为草稿。";
            await ReloadAsync();
        }
        catch (Exception exception) { errorMessage = exception.Message; }
        finally { isSaving = false; }
    }

    /// <summary>
    /// 二次确认后删除感悟。
    /// </summary>
    private async Task DeleteAsync(ThoughtItem thought)
    {
        if (!await JavaScript.InvokeAsync<bool>("confirm", "确认删除这条感悟吗？")) return;
        try
        {
            await Api.DeleteThoughtAsync(thought.Id);
            successMessage = "感悟已删除。";
            await ReloadAsync();
        }
        catch (Exception exception) { errorMessage = exception.Message; }
    }

    /// <summary>
    /// 移除当前表单中的配图引用。
    /// </summary>
    private void RemoveImage() => imageUrl = null;

    /// <summary>
    /// 关闭编辑器。
    /// </summary>
    private void CancelEdit() => showEditor = false;

    /// <summary>
    /// 将逗号、分号、顿号或换行分隔的输入转换为规范标签集合。
    /// </summary>
    private string[] ParseTags()
    {
        return ThoughtTagRules.Normalize(tagsText.Split([',', '，', '、', ';', '；', '\r', '\n']));
    }

    /// <summary>
    /// 安全读取标签并兼容旧版本接口响应。
    /// </summary>
    private static string[] GetTags(ThoughtItem thought)
    {
        return thought.Tags ?? [];
    }

    /// <summary>
    /// 从常用标签中添加或移除编辑器标签。
    /// </summary>
    private void ToggleEditorTag(string tag)
    {
        var tags = ParseTags().ToList();
        var existing = tags.FindIndex(item => string.Equals(item, tag, StringComparison.OrdinalIgnoreCase));
        if (existing >= 0)
        {
            tags.RemoveAt(existing);
        }
        else if (tags.Count < ThoughtTagRules.MaxTagCount)
        {
            tags.Add(tag);
        }

        tagsText = string.Join("、", tags);
    }

    /// <summary>
    /// 判断常用标签是否已加入当前编辑器。
    /// </summary>
    private bool IsEditorTagSelected(string tag)
    {
        return ParseTags().Contains(tag, StringComparer.OrdinalIgnoreCase);
    }

    /// <summary>
    /// 选中分类标签；再次点击已选标签时恢复全部感悟。
    /// </summary>
    private void SelectTag(string? tag)
    {
        selectedTag = tag is not null && IsFilterTagSelected(tag) ? null : tag;
    }

    /// <summary>
    /// 判断列表筛选器是否选中了指定标签。
    /// </summary>
    private bool IsFilterTagSelected(string tag)
    {
        return string.Equals(selectedTag, tag, StringComparison.OrdinalIgnoreCase);
    }
}
