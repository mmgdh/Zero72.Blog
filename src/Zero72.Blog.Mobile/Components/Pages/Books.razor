@page "/books"
@inherits AuthenticatedPageBase
@inject IJSRuntime JavaScript

<PageTitle>所读书籍 · Zero72 博客助手</PageTitle>

<section class="page">
    <header class="page-heading heading-row">
        <div><p class="eyebrow">Reading Library</p><h1>所读书籍</h1><p>先维护书籍，再添加对应的阅读记录。</p></div>
        <button class="primary compact" @onclick="StartCreate">＋ 添加</button>
    </header>

    @if (!string.IsNullOrWhiteSpace(errorMessage)) { <div class="alert error">@errorMessage</div> }
    @if (!string.IsNullOrWhiteSpace(successMessage)) { <div class="alert success">@successMessage</div> }

    @if (showEditor)
    {
        <section class="panel editor-panel">
            <div class="section-title"><h2>@(editingId is null ? "添加书籍" : "编辑书籍")</h2></div>
            <div class="form-stack">
                <label class="field"><span>书名</span><input @bind="title" placeholder="请输入书名" /></label>
                <label class="field"><span>作者</span><input @bind="author" placeholder="请输入作者" /></label>
                <label class="field"><span>卡片主题色</span><input type="color" @bind="coverTone" /></label>
                <label class="field">
                    <span>封面图片</span>
                    <InputFile OnChange="UploadCoverAsync" accept="image/jpeg,image/png,image/webp,image/gif" />
                    <small>支持 JPG、PNG、WebP、GIF，最大 5 MB。</small>
                </label>
                @if (!string.IsNullOrWhiteSpace(coverImageUrl))
                {
                    <div class="image-preview"><RemoteImage ImagePath="@coverImageUrl" Alt="封面预览" Lazy="false" /><button class="text-button danger-text" @onclick="RemoveCover">移除封面</button></div>
                }
                <div class="button-row">
                    <button class="primary" disabled="@isSaving" @onclick="SaveAsync">@(isSaving ? "正在保存…" : "保存书籍")</button>
                    <button class="secondary" @onclick="CancelEdit">取消</button>
                </div>
            </div>
        </section>
    }

    @if (isLoading)
    {
        <div class="loading-card">正在读取图书…</div>
    }
    else if (books.Count == 0)
    {
        <div class="empty-state"><strong>书架还是空的</strong><p>添加第一本正在阅读的书。</p></div>
    }
    else
    {
        <div class="book-grid">
            @foreach (var book in books)
            {
                <article class="book-card">
                    <div class="book-cover" style="--book-tone:@book.CoverTone">
                        @if (!string.IsNullOrWhiteSpace(book.CoverImageUrl))
                        {
                            <RemoteImage ImagePath="@book.CoverImageUrl" Alt="@($"{book.Title} 封面")">
                                <Fallback><span>@book.Title.FirstOrDefault()</span></Fallback>
                            </RemoteImage>
                        }
                        else
                        {
                            <span>@book.Title.FirstOrDefault()</span>
                        }
                    </div>
                    <div class="book-copy"><h2>@book.Title</h2><p>@book.Author</p><small>@book.RecordCount 条记录 · @book.TotalHours.ToString("0.0") 小时</small></div>
                    <div class="card-actions vertical-actions">
                        <button class="text-button" @onclick="() => Edit(book)">编辑</button>
                        <button class="text-button danger-text" disabled="@(book.RecordCount > 0)" @onclick="() => DeleteAsync(book)">删除</button>
                    </div>
                </article>
            }
        </div>
    }
</section>

@code {
    private const long MaxUploadBytes = 5 * 1024 * 1024;
    private readonly List<ReadingBook> books = [];
    private Guid? editingId;
    private string title = string.Empty;
    private string author = string.Empty;
    private string coverTone = "#2563eb";
    private string? coverImageUrl;
    private string? errorMessage;
    private string? successMessage;
    private bool isLoading = true;
    private bool isSaving;
    private bool showEditor;

    /// <summary>
    /// 验证登录状态并加载书籍列表。
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        if (!await EnsureAuthenticatedAsync()) return;
        await ReloadAsync();
        if (Navigation.Uri.Contains("new=1", StringComparison.OrdinalIgnoreCase)) StartCreate();
    }

    /// <summary>
    /// 从服务器刷新全部图书。
    /// </summary>
    private async Task ReloadAsync()
    {
        isLoading = true;
        try
        {
            books.Clear();
            books.AddRange((await Api.GetBooksAsync()).OrderByDescending(item => item.LastReadDate).ThenBy(item => item.Title));
        }
        catch (Exception exception) { errorMessage = exception.Message; }
        finally { isLoading = false; }
    }

    /// <summary>
    /// 清空表单并进入新增模式。
    /// </summary>
    private void StartCreate()
    {
        editingId = null;
        title = string.Empty;
        author = string.Empty;
        coverTone = "#2563eb";
        coverImageUrl = null;
        showEditor = true;
        successMessage = null;
    }

    /// <summary>
    /// 将图书信息填入编辑器。
    /// </summary>
    private void Edit(ReadingBook book)
    {
        editingId = book.Id;
        title = book.Title;
        author = book.Author;
        coverTone = book.CoverTone;
        coverImageUrl = book.CoverImageUrl;
        showEditor = true;
    }

    /// <summary>
    /// 上传用户选择或拍摄的封面图片。
    /// </summary>
    private async Task UploadCoverAsync(InputFileChangeEventArgs eventArgs)
    {
        errorMessage = null;
        try
        {
            var file = eventArgs.File;
            await using var stream = file.OpenReadStream(MaxUploadBytes);
            coverImageUrl = (await Api.UploadImageAsync(stream, file.Name, file.ContentType)).Url;
        }
        catch (Exception exception) { errorMessage = $"封面上传失败：{exception.Message}"; }
    }

    /// <summary>
    /// 校验并保存图书。
    /// </summary>
    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(title) || string.IsNullOrWhiteSpace(author))
        {
            errorMessage = "请填写书名和作者。";
            return;
        }

        isSaving = true;
        errorMessage = null;
        try
        {
            await Api.SaveBookAsync(editingId, new SaveReadingBookRequest(title.Trim(), author.Trim(), coverTone, coverImageUrl));
            showEditor = false;
            successMessage = "书籍信息已同步到博客。";
            await ReloadAsync();
        }
        catch (Exception exception) { errorMessage = exception.Message; }
        finally { isSaving = false; }
    }

    /// <summary>
    /// 仅允许删除尚无阅读记录的书籍。
    /// </summary>
    private async Task DeleteAsync(ReadingBook book)
    {
        if (book.RecordCount > 0 || !await JavaScript.InvokeAsync<bool>("confirm", $"确认删除《{book.Title}》吗？")) return;
        try
        {
            await Api.DeleteBookAsync(book.Id);
            successMessage = "书籍已删除。";
            await ReloadAsync();
        }
        catch (Exception exception) { errorMessage = exception.Message; }
    }

    /// <summary>
    /// 移除当前表单中的封面引用。
    /// </summary>
    private void RemoveCover() => coverImageUrl = null;

    /// <summary>
    /// 关闭编辑器。
    /// </summary>
    private void CancelEdit() => showEditor = false;
}
