@page "/settings"
@inject MobileSettingsService MobileSettings
@inject BlogApiClient Api
@inject AppUpdateService AppUpdates
@inject AppLogService Logs
@inject SessionState Session
@inject NavigationManager Navigation
@inject IJSRuntime JavaScript

<PageTitle>设置 · Zero72 博客助手</PageTitle>

<section class="page">
    <header class="page-heading">
        <p class="eyebrow">连接与账号</p>
        <h1>设置</h1>
        <p>管理博客服务器连接、登录状态和安卓应用版本。</p>
    </header>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="alert @(isError ? "error" : "success")">@message</div>
    }

    <section class="panel form-stack">
        <label class="field">
            <span>博客服务器地址</span>
            <input inputmode="url" @bind="baseUrl" placeholder="http://47.114.74.197:8080/" />
            <small>修改后需要重新登录；当前服务器使用 HTTP，建议后续配置 HTTPS。</small>
        </label>
        <button class="primary" @onclick="SaveAsync">保存并测试连接</button>
    </section>

    <section class="panel">
        <div class="section-title">
            <div><h2>应用更新</h2><p>当前版本 @AppUpdates.CurrentVersion</p></div>
            <span class="version-badge">Android</span>
        </div>
        @if (availableUpdate is not null)
        {
            <div class="available-update">
                <strong>发现 @availableUpdate.VersionName (@availableUpdate.VersionCode)</strong>
                <p>@(string.IsNullOrWhiteSpace(availableUpdate.ReleaseNotes) ? "包含功能优化与稳定性改进。" : availableUpdate.ReleaseNotes)</p>
                <button class="primary" disabled="@isCheckingUpdate" @onclick="OpenUpdateAsync">下载安装包</button>
            </div>
        }
        else
        {
            <button class="secondary" disabled="@isCheckingUpdate" @onclick="CheckUpdateAsync">
                @(isCheckingUpdate ? "正在检查…" : "检查新版本")
            </button>
        }
    </section>

    <section class="panel">
        <div class="section-title">
            <div><h2>诊断日志</h2><p>记录应用、API 响应和图片加载结果</p></div>
            <span class="version-badge">LOG</span>
        </div>
        <p class="diagnostic-hint">图片失败后会自动用原生 HTTP 复查同一地址。日志不记录密码、Cookie 或请求正文；复制前仍请留意其中的个人博客内容。</p>
        <div class="diagnostic-actions">
            <button class="secondary compact" @onclick="RefreshLogsAsync">刷新日志</button>
            <button class="secondary compact" @onclick="CopyLogsAsync">复制日志</button>
            <button class="text-button danger-text" @onclick="ClearLogsAsync">清空</button>
        </div>
        <pre class="diagnostic-log">@logContent</pre>
    </section>

    <section class="panel">
        <div class="section-title">
            <div><h2>当前账号</h2><p>@(Session.IsAuthenticated ? Session.UserName : "尚未登录")</p></div>
        </div>
        @if (Session.IsAuthenticated)
        {
            <button class="secondary" @onclick="LogoutAsync">退出登录</button>
        }
        else
        {
            <NavLink class="button-link primary" href="/login">前往登录</NavLink>
        }
    </section>

    <section class="panel subtle-panel">
        <h2>安全说明</h2>
        <p>应用不会保存密码。登录 Cookie 加密保存在 Android 安全存储中，默认有效期为7天；退出登录、会话过期或服务端修改管理员密码后会自动失效。安装更新时 Android 会要求你确认安装来源和应用签名。</p>
    </section>
</section>

@code {
    private string baseUrl = string.Empty;
    private string? message;
    private bool isError;
    private bool isCheckingUpdate;
    private MobileReleaseInfo? availableUpdate;
    private string logContent = "正在读取日志…";

    /// <summary>
    /// 读取当前保存的服务器地址。
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        baseUrl = MobileSettings.GetBaseUri().AbsoluteUri;
        await RefreshLogsAsync();
    }

    /// <summary>
    /// 校验并保存服务器地址，然后通过认证状态接口测试连通性。
    /// </summary>
    private async Task SaveAsync()
    {
        message = null;
        isError = false;
        try
        {
            MobileSettings.SaveBaseUrl(baseUrl);
            baseUrl = MobileSettings.GetBaseUri().AbsoluteUri;
            Session.Update(false, null);
            await Api.GetStatusAsync();
            message = "服务器连接正常，请重新登录。";
        }
        catch (Exception exception)
        {
            isError = true;
            message = $"连接失败：{exception.Message}";
        }
    }

    /// <summary>
    /// 手动检查服务器升级清单，并显示没有更新或请求失败的明确结果。
    /// </summary>
    private async Task CheckUpdateAsync()
    {
        isCheckingUpdate = true;
        message = null;
        isError = false;
        try
        {
            availableUpdate = await AppUpdates.CheckAsync();
            if (availableUpdate is null)
            {
                message = "当前已经是最新版本。";
            }
        }
        catch (Exception exception)
        {
            isError = true;
            message = $"检查更新失败：{exception.Message}";
        }
        finally
        {
            isCheckingUpdate = false;
        }
    }

    /// <summary>
    /// 通过系统浏览器打开已校验的 APK 下载地址。
    /// </summary>
    private async Task OpenUpdateAsync()
    {
        if (availableUpdate is null)
        {
            return;
        }

        isCheckingUpdate = true;
        try
        {
            await AppUpdates.OpenDownloadAsync(availableUpdate);
        }
        catch (Exception exception)
        {
            isError = true;
            message = $"打开下载失败：{exception.Message}";
        }
        finally
        {
            isCheckingUpdate = false;
        }
    }

    /// <summary>
    /// 注销服务端会话并返回登录页。
    /// </summary>
    private async Task LogoutAsync()
    {
        try
        {
            await Api.LogoutAsync();
        }
        finally
        {
            Navigation.NavigateTo("/login", replace: true);
        }
    }

    /// <summary>
    /// 从应用私有日志文件重新读取最近内容。
    /// </summary>
    private async Task RefreshLogsAsync()
    {
        logContent = await Logs.ReadAsync();
    }

    /// <summary>
    /// 将当前完整可见日志复制到系统剪贴板。
    /// </summary>
    private async Task CopyLogsAsync()
    {
        await RefreshLogsAsync();
        await Clipboard.Default.SetTextAsync(logContent);
        isError = false;
        message = "诊断日志已复制。";
    }

    /// <summary>
    /// 用户确认后删除设备上的历史诊断日志。
    /// </summary>
    private async Task ClearLogsAsync()
    {
        if (!await JavaScript.InvokeAsync<bool>("confirm", "确认清空全部诊断日志吗？"))
        {
            return;
        }

        await Logs.ClearAsync();
        await Logs.InfoAsync("应用", "用户已清空诊断日志。");
        await RefreshLogsAsync();
        isError = false;
        message = "诊断日志已清空。";
    }
}
